# ============================================
# PROPEDGE — ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your keys
# ============================================

# --- REQUIRED ---
# The Odds API (https://the-odds-api.com)
# Sign up free → 500 requests/month
ODDS_API_KEY=
# --- NBA Stats (RapidAPI NBA Free Data) ---
# https://rapidapi.com/Creativesdev/api/nba-api-free-data
# Already configured as NBA_RAPID_KEY in Vercel env vars
NBA_RAPID_KEY=

# --- SERVER ---
PORT=3000
NODE_ENV=production

# --- CACHE TTL (seconds) ---
CACHE_TTL_ODDS=120
CACHE_TTL_SCORES=30
CACHE_TTL_STATS=43200
CACHE_TTL_DVP=600
