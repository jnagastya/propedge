{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": { "maxDuration": 120 }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/(.*)", "dest": "server.js" }
  ],
  "crons": [
    { "path": "/api/cron/refresh-odds", "schedule": "45 22 * * 1-5" },
    { "path": "/api/cron/refresh-stats", "schedule": "55 22 * * 1-5" },
    { "path": "/api/cron/refresh-team-stats", "schedule": "50 22 * * 1-5" },

    { "path": "/api/cron/refresh-odds", "schedule": "0 17 * * 0,6" },
    { "path": "/api/cron/refresh-stats", "schedule": "15 17 * * 0,6" },
    { "path": "/api/cron/refresh-team-stats", "schedule": "30 17 * * 0,6" },

    { "path": "/api/cron/grade-agent-bets", "schedule": "0 19 * * *" },
    { "path": "/api/cron/grade-bets", "schedule": "15 19 * * *" },
    { "path": "/api/cron/newsletter", "schedule": "30 19 * * *" },

    { "path": "/api/cron/refresh-odds", "schedule": "0 23 * * 0,6" },

    { "path": "/api/cron/refresh-game-lines", "schedule": "45 22 * * 1-5" },
    { "path": "/api/cron/refresh-game-lines", "schedule": "0 17 * * 0,6" },
    { "path": "/api/cron/refresh-game-lines", "schedule": "0 1 * * 0,1" },

    { "path": "/api/cron/agent-bet", "schedule": "15 23 * * 1-5" },
    { "path": "/api/cron/agent-bet", "schedule": "30 17 * * 0,6" },

    { "path": "/api/cron/tipoff-snapshot", "schedule": "0 18 * * 0,6" },
    { "path": "/api/cron/tipoff-snapshot", "schedule": "0 20 * * 0,6" },
    { "path": "/api/cron/tipoff-snapshot", "schedule": "0 22 * * 0,6" },

    { "path": "/api/cron/tipoff-snapshot", "schedule": "0 0 * * *" },
    { "path": "/api/cron/tipoff-snapshot", "schedule": "0 1 * * *" },
    { "path": "/api/cron/tipoff-snapshot", "schedule": "0 2 * * *" },
    { "path": "/api/cron/tipoff-snapshot", "schedule": "0 3 * * *" }
  ]
}
